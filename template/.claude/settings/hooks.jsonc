{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh \"./.claude/hooks/caveman-activate.sh\"",
            "timeout": 5,
            "statusMessage": "Loading caveman mode...",
          },
        ],
      },
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh \"./.claude/hooks/caveman-mode-tracker.sh\"",
            "timeout": 5,
            "statusMessage": "Tracking caveman mode...",
          },
        ],
      },
    ],
  },
}
