{% raw %}name: CI

on:
  push:
    branches-ignore:
      - 'gh-readonly-queue/**' # don't run (again) when on these special branches created during merge groups; the `on: merge_group` already triggers it.
  merge_group:
  pull_request:

env:
  PYTHONUNBUFFERED: True
  PRE_COMMIT_HOME: ${{ github.workspace }}/.precommit_cache

permissions:
  id-token: write # needed to assume OIDC roles (e.g. for downloading from CodeArtifact)
  contents: write # needed for mutex, and updating dependabot branches
  statuses: write # needed for updating status on Dependabot PRs

jobs:
  get-values:
    uses: ./.github/workflows/get-values.yaml

  check-skip-duplicate:
    runs-on: {% endraw %}{{ gha_linux_runner }}{% raw %}
    permissions:
      contents: read
      pull-requests: read # needed to check if PR exists for current branch
    outputs:
      should-run: ${{ steps.check.outputs.should-run }}
    steps:
      - name: Checkout code
        uses: actions/checkout@{% endraw %}{{ gha_checkout }}{% raw %}
        with:
          persist-credentials: false
      - id: check
        uses: ./.github/actions/check-skip-duplicates

  lint:
    needs:
      - get-values
      - check-skip-duplicate
    if: needs.check-skip-duplicate.outputs.should-run == 'true'
    name: Pre-commit
    uses: ./.github/workflows/pre-commit.yaml
    with:
      python-version: {% endraw %}{{ python_version }}{% raw %}
      setup-node: true
      node-version: {% endraw %}{{ node_version }}{% raw %}

  unit-test-frontend:
    name: Unit Test Frontend
    timeout-minutes: {% endraw %}{{ gha_medium_timeout_minutes }}{% raw %}
    runs-on: {% endraw %}{{ gha_linux_runner }}{% raw %}
    needs:
      - lint
      - check-skip-duplicate
    if: needs.check-skip-duplicate.outputs.should-run == 'true'
    steps:
      - name: Checkout code
        uses: actions/checkout@{% endraw %}{{ gha_checkout }}{% raw %}

      - name: Install latest versions of packages
        uses: ./.github/actions/install_deps
        with:
          node-version: {% endraw %}{{ node_version }}{% raw %}
          skip-installing-ssm-plugin-manager: true

      - name: Unit test
        run: pnpm --dir=frontend test-unit

      - name: Upload test coverage on failure
        if: ${{ failure() }}
        uses: actions/upload-artifact@{% endraw %}{{ gha_upload_artifact }}{% raw %}
        with:
          name: frontend-test-coverage
          path: frontend/.coverage
          if-no-files-found: error
          include-hidden-files: true{% endraw %}{% if has_backend %}{% raw %}

  unit-test-backend:
    name: Unit Test Backend
    timeout-minutes: {% endraw %}{{ gha_medium_timeout_minutes }}{% raw %}
    needs:
      - lint
      - check-skip-duplicate
    if: needs.check-skip-duplicate.outputs.should-run == 'true'
    strategy:
      matrix:
        os:
          - "{% endraw %}{{ gha_linux_runner }}{% raw %}"{% endraw %}{% if use_windows_in_ci %}
          - {{ gha_windows_runner }}{% endif %}{% raw %}
    runs-on: ${{ matrix.os }}
    steps:
      - name: Checkout code
        uses: actions/checkout@{% endraw %}{{ gha_checkout }}{% raw %}

      - name: Install latest versions of python packages
        uses: ./.github/actions/install_deps
        with:
          python-version: {% endraw %}{{ python_version }}{% raw %}
          skip-installing-ssm-plugin-manager: true

      - name: Unit test
        run: uv --directory=backend run pytest tests/unit --durations=5

      - name: Upload test coverage on failure
        if: ${{ failure() }}
        uses: actions/upload-artifact@{% endraw %}{{ gha_upload_artifact }}{% raw %}
        with:
          name: backend-test-coverage-${{ matrix.os }}
          path: backend/coverage-report-pytest
          if-no-files-found: error{% endraw %}{% endif %}{% raw %}

  build-frontend:
    needs:
      - lint
      - unit-test-frontend{% endraw %}{% if has_backend %}{% raw %}
      - unit-test-backend{% endraw %}{% endif %}{% raw %}
      - check-skip-duplicate
    if: needs.check-skip-duplicate.outputs.should-run == 'true'
{% endraw %}{% if not deploy_as_executable %}{% raw %}    uses: ./.github/workflows/build-docker-image.yaml
    with:
      context: ./frontend
      save-as-artifact: true
      tag-for-production: ${{ github.ref == 'refs/heads/main' }}
      repository: {% endraw %}{{ frontend_ecr_base_url }}{% raw %}
      image_name: {% endraw %}{{ frontend_image_name }}{% raw %}
{% endraw %}{% if push_to_ecr %}{% raw %}      push-role-name: {% endraw %}{{ frontend_ecr_push_role_name }}{% endif %}{% else %}{% raw %}
    timeout-minutes: {% endraw %}{{ gha_medium_timeout_minutes }}{% raw %}
    runs-on: {% endraw %}{{ gha_linux_runner }}{% raw %}
    steps:
      - name: Checkout code
        uses: actions/checkout@{% endraw %}{{ gha_checkout }}{% raw %}

      - name: Install latest versions of node packages
        uses: ./.github/actions/install_deps
        with:
          node-version: {% endraw %}{{ node_version }}{% raw %}
          skip-installing-ssm-plugin-manager: true

      - name: Build frontend
        run: pnpm --dir=frontend generate

      - name: Upload build artifact
        uses: actions/upload-artifact@{% endraw %}{{ gha_upload_artifact }}{% raw %}
        with:
          name: frontend-static-assets
          path: frontend/.output/public/**/*
          if-no-files-found: error

{% endraw %}{% endif %}{% raw %}

{% endraw %}{% if has_backend %}{% raw %}{% endraw %}{% if not deploy_as_executable %}{% raw %}
  build-backend:
    needs:
      - lint
      - unit-test-frontend
      - unit-test-backend
      - check-skip-duplicate
    if: needs.check-skip-duplicate.outputs.should-run == 'true'
    uses: ./.github/workflows/build-docker-image.yaml
    with:
      context: ./backend
      save-as-artifact: true
      tag-for-production: ${{ github.ref == 'refs/heads/main' }}
      repository: {% endraw %}{{ backend_ecr_base_url }}{% raw %}
      image_name: {% endraw %}{{ backend_image_name }}{% raw %}
{% endraw %}{% if push_to_ecr %}{% raw %}      push-role-name: {% endraw %}{{ backend_ecr_push_role_name }}{% endif %}{% else %}{% raw %}
  build-backend:
    needs:
      - lint
      - unit-test-frontend
      - unit-test-backend
      - build-frontend
      - check-skip-duplicate
    if: needs.check-skip-duplicate.outputs.should-run == 'true'
    strategy:
      matrix:
        os:
          - "{% endraw %}{{ gha_linux_runner }}{% raw %}"{% endraw %}{% if use_windows_in_ci %}
          - {{ gha_windows_runner }}{% endif %}{% raw %}
    timeout-minutes: {% endraw %}{{ gha_medium_timeout_minutes }}{% raw %}
    runs-on: ${{ matrix.os }}

    steps:
      - name: Checkout code
        uses: actions/checkout@{% endraw %}{{ gha_checkout }}{% raw %}
      - name: Download Frontend Static Assets
        uses: actions/download-artifact@{% endraw %}{{ gha_download_artifact }}{% raw %}
        with:
          name: frontend-static-assets
          path: backend/src/static

      - name: Install latest versions of python packages
        uses: ./.github/actions/install_deps
        with:
          python-version: {% endraw %}{{ python_version }}{% raw %}
          skip-installing-ssm-plugin-manager: true

      - name: Build application
        working-directory: backend
        run: uv run pyinstaller pyinstaller.spec --log-level=DEBUG
      - name: Tar files to preserve permissions on Linux during artifact upload # https://github.com/actions/upload-artifact?tab=readme-ov-file#permission-loss
        run: tar -cvf app.tar backend/dist/{% endraw %}{{ repo_name }}{% raw %}
      - name: Upload application artifact (Windows)
        if: runner.os == 'Windows'
        uses: actions/upload-artifact@{% endraw %}{{ gha_upload_artifact }}{% raw %}
        with:
          name: built-{% endraw %}{{ repo_name }}{% raw %}-${{ matrix.os }}
          path: backend/dist/{% endraw %}{{ repo_name }}{% raw %}/**/*
          if-no-files-found: error
      - name: Upload application artifact (Linux)
        if: runner.os == 'Linux'
        uses: actions/upload-artifact@{% endraw %}{{ gha_upload_artifact }}{% raw %}
        with:
          name: built-{% endraw %}{{ repo_name }}{% raw %}-${{ matrix.os }}
          path: app.tar
          if-no-files-found: error{% endraw %}{% endif %}{% raw %}{% endraw %}{% endif %}{% raw %}


  test-compiled-frontend:
    name: Test the compiled Frontend
    timeout-minutes: {% endraw %}{{ gha_medium_timeout_minutes }}{% raw %}
    runs-on: {% endraw %}{{ gha_linux_runner }}{% raw %}
    needs:
      - build-frontend{% endraw %}{% if has_backend %}{% raw %}
      - build-backend{% endraw %}{% endif %}{% raw %}
      - check-skip-duplicate
    if: needs.check-skip-duplicate.outputs.should-run == 'true'
    steps:
      - name: Checkout code
        uses: actions/checkout@{% endraw %}{{ gha_checkout }}{% raw %}

      - name: Install latest versions of node packages
        uses: ./.github/actions/install_deps
        with:
          node-version: {% endraw %}{{ node_version }}{% raw %}
          skip-installing-ssm-plugin-manager: true

      - name: Test
        run: pnpm --dir=frontend test-compiled{% endraw %}{% if run_backend_e2e_in_ci %}{% raw %}

  e2e-test-backend:
    name: End-to-end Testing of the Backend
    strategy:
      matrix:
        os:
          - "{% endraw %}{{ gha_linux_runner }}{% raw %}"
    runs-on: ${{ matrix.os }}
    needs:
      - build-backend
      - check-skip-duplicate
    if: needs.check-skip-duplicate.outputs.should-run == 'true'
    steps:
      - name: Checkout code
        uses: actions/checkout@{% endraw %}{{ gha_checkout }}{% raw %}

      - name: Install latest versions of python packages
        uses: ./.github/actions/install_deps
        with:
          python-version: {% endraw %}{{ python_version }}{% raw %}
          skip-installing-ssm-plugin-manager: true

      - name: Download Backend Artifact
        uses: actions/download-artifact@{% endraw %}{{ gha_download_artifact }}{% raw %}
        with:
          name: ${{ needs.build-backend.outputs.artifact-name }}
          path: deployment-package-folder{% endraw %}{% if auth_to_ecr_for_backend_e2e_in_ci %}{% raw %}

      - name: ECR Auth to pull images for E2E tests
        uses: ./.github/actions/ecr-auth
        with:
          aws-region: {% endraw %}{{ auth_to_ecr_for_backend_e2e_in_ci_region }}{% raw %}
          role-arn: {% endraw %}{{ auth_to_ecr_for_backend_e2e_in_ci_role_arn }}{% raw %}{% endraw %}{% endif %}{% raw %}

      - name: Load docker images
        run: |
          ls deployment-package-folder -a
          # load all images in the folder
          ls -1 deployment-package-folder/*.tar | xargs --no-run-if-empty -L 1 docker load -i

      - name: Retag loaded backend image to stable local name
        run: docker tag ${{ needs.build-backend.outputs.full-image-tag }} {% endraw %}{{ backend_image_name }}{% raw %}:local

      - name: E2E test
        run: uv --directory=backend run pytest tests/e2e --durations=5{% endraw %}{% endif %}{% raw %}

  e2e-test:
    name: End-to-end Testing
    timeout-minutes: {% endraw %}{{ gha_long_timeout_minutes }}{% raw %}
    strategy:
      matrix:
        os:
          - "{% endraw %}{{ gha_linux_runner }}{% raw %}"{% endraw %}{% if use_windows_in_ci %}
          - {{ gha_windows_runner }}{% endif %}{% raw %}
    runs-on: ${{ matrix.os }}
    needs:
      - build-frontend{% endraw %}{% if has_backend %}{% raw %}
      - build-backend{% endraw %}{% endif %}{% raw %}
      - check-skip-duplicate
    if: needs.check-skip-duplicate.outputs.should-run == 'true'
    steps:
      - name: Checkout code
        uses: actions/checkout@{% endraw %}{{ gha_checkout }}{% raw %}

      - name: Install latest versions of node packages
        uses: ./.github/actions/install_deps
        with:
          node-version: {% endraw %}{{ node_version }}{% raw %}{% endraw %}{% if not deploy_as_executable %}{% raw %}
{% endraw %}{% if has_backend %}{% raw %}
      - name: Download Backend Artifact
        uses: actions/download-artifact@{% endraw %}{{ gha_download_artifact }}{% raw %}
        with:
          name: ${{ needs.build-backend.outputs.artifact-name }}
          path: deployment-package-folder{% endraw %}{% endif %}{% raw %}

      - name: Download Frontend Artifact
        uses: actions/download-artifact@{% endraw %}{{ gha_download_artifact }}{% raw %}
        with:
          name: {% endraw %}{{ frontend_image_name | replace('/', '-') }}{% raw %}
          path: deployment-package-folder

      - name: Load docker images
        run: |
          ls deployment-package-folder -a
          # load all images in the folder
          ls -1 deployment-package-folder/*.tar | xargs --no-run-if-empty -L 1 docker load -i

      - name: Retag loaded images to stable local names
        run: |
          docker tag ${{ needs.build-frontend.outputs.full-image-tag }} {% endraw %}{{ frontend_image_name }}{% raw %}:local{% endraw %}{% if has_backend %}{% raw %}
          docker tag ${{ needs.build-backend.outputs.full-image-tag }} {% endraw %}{{ backend_image_name }}{% raw %}:local{% endraw %}{% endif %}{% raw %}
{% endraw %}{% else %}{% raw %}
      - name: Download Built executable
        uses: actions/download-artifact@{% endraw %}{{ gha_download_artifact }}{% raw %}
        with:
          name: built-{% endraw %}{{ repo_name }}{% raw %}-${{ matrix.os }}
          path: backend/dist/{% endraw %}{{ repo_name }}{% raw %}
      - name: Untar the artifact (on Linux)
        if: runner.os == 'Linux'
        run: tar -xvf backend/dist/{% endraw %}{{ repo_name }}{% raw %}/app.tar -C .
{% endraw %}{% endif %}{% raw %}{% endraw %}{% if auth_to_ecr_for_e2e_in_ci %}{% raw %}

      - name: ECR Auth to pull images for E2E tests
        uses: ./.github/actions/ecr-auth
        with:
          aws-region: {% endraw %}{{ auth_to_ecr_for_e2e_in_ci_region }}{% raw %}
          role-arn: {% endraw %}{{ auth_to_ecr_for_e2e_in_ci_role_arn }}{% raw %}{% endraw %}{% endif %}{% raw %}
      - name: E2E test
        run: pnpm --dir=frontend test-e2e

{% endraw %}{% if create_docker_image_tar_artifact %}{% raw %}  package-images:
    name: Package Images
    timeout-minutes: {% endraw %}{{ gha_medium_timeout_minutes }}{% raw %}
    runs-on: {% endraw %}{{ gha_linux_runner }}{% raw %}
    needs:
      - build-frontend{% endraw %}{% if has_backend %}{% raw %}
      - build-backend{% endraw %}{% endif %}{% raw %}
      - check-skip-duplicate
    if: needs.check-skip-duplicate.outputs.should-run == 'true'
    steps:
    - name: Checkout repository
      uses: actions/checkout@{% endraw %}{{ gha_checkout }}{% raw %}
    - name: Prepare docker-compose file
      run: |
        mkdir -p deployment-package-folder
        cp deployment/docker-compose.yaml deployment-package-folder/docker-compose.yaml
        sed -i '/image:/s/:latest/:${{ github.sha }}/g' deployment-package-folder/docker-compose.yaml{% endraw %}{% if has_backend %}{% raw %}

    - name: Download Backend Artifact
      uses: actions/download-artifact@{% endraw %}{{ gha_download_artifact }}{% raw %}
      with:
        name: ${{ needs.build-backend.outputs.artifact-name }}
        path: deployment-package-folder{% endraw %}{% endif %}{% raw %}

    - name: Download Frontend Artifact
      uses: actions/download-artifact@{% endraw %}{{ gha_download_artifact }}{% raw %}
      with:
        name: ${{ needs.build-frontend.outputs.artifact-name }}
        path: deployment-package-folder

    - name: Upload deployment package artifact
      uses: actions/upload-artifact@{% endraw %}{{ gha_upload_artifact }}{% raw %}
      with:
        name: {% endraw %}{{ repo_name }}{% raw %}-deployment-package
        path: deployment-package-folder/**/*
        if-no-files-found: error{% endraw %}{% endif %}{% raw %}{% endraw %}{% if is_circuit_python_driver %}{% raw %}

  package-firmware:
    name: Package Firmware
    timeout-minutes: {% endraw %}{{ gha_short_timeout_minutes }}{% raw %}
    runs-on: {% endraw %}{{ gha_linux_runner }}{% raw %}
    needs:
      - build-frontend
      - build-backend
      - check-skip-duplicate
    if: needs.check-skip-duplicate.outputs.should-run == 'true'
    steps:
    - name: Checkout repository
      uses: actions/checkout@{% endraw %}{{ gha_checkout }}{% raw %}

    - name: Install latest versions of python packages
      uses: ./.github/actions/install_deps
      with:
        python-version: {% endraw %}{{ python_version }}{% raw %}
        skip-installing-ssm-plugin-manager: true

    - name: Extract firmware version
      id: get-version
      run: |
        VERSION=$(uv --directory=backend run python -c "from backend_api.firmware.src.code_lib import VERSION; print(VERSION)")
        echo "version=$VERSION" >> $GITHUB_OUTPUT

    - name: Install CircuitPython libraries
      run: uv --directory=backend run circup --path=./src/backend_api/firmware/src/ install -r ./src/backend_api/firmware/requirements.txt

    - name: Verify CircuitPython libraries installed
      run: uv --directory=backend run circup --path=./src/backend_api/firmware/src/ freeze

    - name: Clean __pycache__ directories
      run: find ./backend/src/backend_api/firmware/src -type d -name '__pycache__' -exec rm -rf {} +

    - name: Upload firmware artifact
      uses: actions/upload-artifact@{% endraw %}{{ gha_upload_artifact }}{% raw %}
      with:
        name: {% endraw %}{{ repo_name.removesuffix('-driver') }}{% raw %}-firmware-v${{ steps.get-version.outputs.version }}
        path: ./backend/src/backend_api/firmware/src/**/*
        if-no-files-found: error{% endraw %}{% endif %}{% raw %}

  confirm-on-tagged-copier-template:
    needs:
      - check-skip-duplicate
    if: ${{ github.event_name == 'pull_request' || github.event_name == 'merge_group' }}
    uses: ./.github/workflows/confirm-on-tagged-copier-template.yaml
    permissions:
      contents: read
      pull-requests: read # needed to check if PR exists for current branch

  workflow-summary:
    runs-on: {% endraw %}{{ gha_linux_runner }}{% raw %}
    timeout-minutes: {% endraw %}{{ gha_short_timeout_minutes }}{% raw %}
    needs:
      - get-values
      - check-skip-duplicate
      - lint
      - unit-test-frontend{% endraw %}{% if create_docker_image_tar_artifact %}{% raw %}
      - package-images{% endraw %}{% endif %}{% raw %}
      - test-compiled-frontend{% endraw %}{% if is_circuit_python_driver %}{% raw %}
      - package-firmware{% endraw %}{% endif %}{% raw %}{% endraw %}{% if run_backend_e2e_in_ci %}{% raw %}
      - e2e-test-backend{% endraw %}{% endif %}{% raw %}
      - e2e-test
      - confirm-on-tagged-copier-template
    permissions:
      statuses: write # needed for updating status on Dependabot PRs
    if: always()
    steps:
      - name: fail if prior job failure
        run: |
          success_pattern="^(skipped|success)$" # these are the possibilities: https://docs.github.com/en/actions/reference/workflows-and-actions/contexts#needs-context

          if [[ ! "${{ needs.get-values.result }}" =~ $success_pattern ]] ||
            [[ ! "${{ needs.check-skip-duplicate.result }}" =~ $success_pattern ]] ||
            [[ ! "${{ needs.lint.result }}" =~ $success_pattern ]] ||
            [[ ! "${{ needs.unit-test-frontend.result }}" =~ $success_pattern ]] ||{% endraw %}{% if create_docker_image_tar_artifact %}{% raw %}
            [[ ! "${{ needs.package-images.result }}" =~ $success_pattern ]] ||{% endraw %}{% endif %}{% raw %}
            [[ ! "${{ needs.test-compiled-frontend.result }}" =~ $success_pattern ]] ||{% endraw %}{% if is_circuit_python_driver %}{% raw %}
            [[ ! "${{ needs.package-firmware.result }}" =~ $success_pattern ]] ||{% endraw %}{% endif %}{% raw %}{% endraw %}{% if run_backend_e2e_in_ci %}{% raw %}
            [[ ! "${{ needs.e2e-test-backend.result }}" =~ $success_pattern ]] ||{% endraw %}{% endif %}{% raw %}
            [[ ! "${{ needs.e2e-test.result }}" =~ $success_pattern ]] ||
            [[ ! "${{ needs.confirm-on-tagged-copier-template.result }}" =~ $success_pattern ]]; then
            echo "❌ One or more jobs did not finish with skipped or success"
            exit 1
          fi
          echo "✅ All jobs finished with skipped or success"

      - name: Mark the required-check as succeeded so the PR can be merged
        if: ${{ github.event_name == 'pull_request' || github.event_name == 'merge_group' }}
        env:
          GH_TOKEN: ${{ github.token }}
        run: |
          gh api \
            -X POST -H "Accept: application/vnd.github.v3+json" \
            "${{ github.event.pull_request.statuses_url }}" \
            -f state=success -f context="required-check" -f description="✅ All required checks passed in the job triggered by pull_request" \
            -f target_url="${{ github.server_url }}/${{ github.repository }}/actions/runs/${{ github.run_id }}"

      - name: Mark updated dependabot hash commit as succeeded
        if: needs.get-values.outputs.dependabot-commit-created == 'true'
        env:
          GH_TOKEN: ${{ github.token }}
        run: |
          gh api \
            -X POST -H "Accept: application/vnd.github.v3+json" \
            "/repos/${{ github.repository }}/statuses/${{ needs.get-values.outputs.new-dependabot-sha }}" \
            -f state=success -f context="required-check" -f description="Initial CI run passed" \
            -f target_url="${{ github.server_url }}/${{ github.repository }}/actions/runs/${{ github.run_id }}"{% endraw %}
