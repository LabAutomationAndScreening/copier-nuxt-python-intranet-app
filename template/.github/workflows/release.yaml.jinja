{% raw %}name: Release

on:
  workflow_dispatch:
    inputs:
      dry_run:
        description: "Dry run (build only, skip release)"
        type: boolean
        default: false

env:
  PYTHONUNBUFFERED: True
  PRE_COMMIT_HOME: ${{ github.workspace }}/.precommit_cache

jobs:
  guard:
    runs-on: {% endraw %}{{ gha_linux_runner }}{% raw %}
    timeout-minutes: {% endraw %}{{ gha_short_timeout_minutes }}{% raw %}
    permissions:
      contents: read # needed for checkout and git ls-remote
      statuses: read # needed to read required-check commit status
    outputs:
      version: ${{ steps.get-version.outputs.version }}
    steps:
      - name: Fail if real release is not on main
        if: ${{ !inputs.dry_run && github.ref != 'refs/heads/main' }}
        run: |
          echo "Real releases must run from main. Current ref: ${{ github.ref }}"
          exit 1
      - name: Check required-check CI status for this commit
        env:
          GH_TOKEN: ${{ github.token }}
        run: |
          STATUS=$(gh api "/repos/${{ github.repository }}/commits/${{ github.sha }}/statuses" --jq '[.[] | select(.context == "required-check")] | first | .state // "not found"')
          echo "required-check status for ${{ github.sha }}: $STATUS"
          if [ "$STATUS" != "success" ] && [ "${{ inputs.dry_run }}" != "true" ]; then
            echo "Wait for CI to pass before releasing."
            exit 1
          fi
      - name: Checkout code
        uses: actions/checkout@{% endraw %}{{ gha_checkout }}{% raw %}
      - name: Extract project version
        id: get-version
        run: |
          VERSION=$(python3 .github/workflows/extract_project_version.py {% endraw %}{% if has_backend %}backend/pyproject.toml{% else %}frontend/package.json{% endif %}{% raw %})
          echo "Project version: $VERSION"
          echo "version=$VERSION" >> $GITHUB_OUTPUT
      - name: Check version tag does not already exist
        run: |
          VERSION="${{ steps.get-version.outputs.version }}"
          if python3 .github/workflows/git_tag.py --version "$VERSION" --confirm-tag-not-present; then
            echo "Tag v$VERSION does not exist yet."
          else
            if [ "${{ inputs.dry_run }}" = "true" ]; then
              echo "Tag v$VERSION already exists (dry run, continuing)."
            else
              echo "Tag v$VERSION already exists. Bump the version before releasing."
              exit 1
            fi
          fi

  {% endraw %}
