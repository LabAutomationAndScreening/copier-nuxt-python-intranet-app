{% raw %}[project]
name = "backend-api"
version = "0.1.0"
description = "API to run GraphQL queries"

readme = "README.md"
requires-python = ">={% endraw %}{{ python_version }}{% raw %}"

dependencies = [
    # Specific to this repository

    # Managed by upstream template
    "fastapi{% endraw %}{{ fastapi_version }}{% raw %}",
    "fastapi-offline{% endraw %}{{ fastapi_offline_version }}{% raw %}",
    "uuid-utils{% endraw %}{{ uuid_utils_version }}{% raw %}",{% endraw %}{% if backend_uses_graphql %}{% raw %}
    "strawberry-graphql{% endraw %}{{ strawberry_graphql_version }}{% raw %}",{% endraw %}{% endif %}{% raw %}
    "pip-system-certs>=5.3",{% endraw %}{% if install_as_windows_service %}{% raw %}
    "pywin32>=311; sys_platform == 'win32'",{% endraw %}{% endif %}{% raw %}
    "pydantic{% endraw %}{{ pydantic_version }}{% raw %}",
    "uvicorn{% endraw %}{{ uvicorn_version }}{% raw %}",
    "structlog{% endraw %}{{ structlog_version }}{% raw %}",{% endraw %}{% if backend_source_uses_kiota %}{% raw %}
    "httpx{% endraw %}{{ httpx_version }}{% raw %}",
    "microsoft-kiota-bundle{% endraw %}{{ python_kiota_bundle_version }}{% raw %}",{% endraw %}{% endif %}{% raw %}{% endraw %}{% if is_circuit_python_driver %}{% raw %}
    "pyserial>=3.5",
    "psutil>=7.2.2",
    "zeroconf>=0.148.0",
    "semver>=3.0.4",{% endraw %}{% endif %}{% raw %}
]


[dependency-groups]
dev = [
    # Specific to this repository


    # Managed by upstream template{% endraw %}{% if not backend_source_uses_kiota %}{% raw %}
    "httpx{% endraw %}{{ httpx_version }}{% raw %}",
    "microsoft-kiota-bundle{% endraw %}{{ python_kiota_bundle_version }}{% raw %}",{% endraw %}{% endif %}{% raw %}{% endraw %}{% if backend_uses_graphql %}{% raw %}
    "ariadne-codegen[subscriptions]{% endraw %}{{ ariadne_codegen_version }}{% raw %}",{% endraw %}{% endif %}{% raw %}
    "pyhumps>=3.8.0",
    "pyright{% endraw %}{{ pyright_version }}{% raw %}",
    "ty{% endraw %}{{ ty_version }}{% raw %}",
    "syrupy{% endraw %}{{ syrupy_version }}{% raw %}",
    "pytest{% endraw %}{{ pytest_version }}{% raw %}",
    "pytest-cov{% endraw %}{{ pytest_cov_version }}{% raw %}",
    "pytest-randomly{% endraw %}{{ pytest_randomly_version }}{% raw %}",
    "pytest-mock{% endraw %}{{ pytest_mock_version }}{% raw %}",{% endraw %}{% if install_as_windows_service %}{% raw %}
    "pytest-timeout>=2.3.1",{% endraw %}{% endif %}{% raw %}
    "pytest-asyncio{% endraw %}{{ pytest_asyncio_version }}{% raw %}",{% endraw %}{% if backend_makes_api_calls %}{% raw %}
    "pytest-recording{% endraw %}{{ pytest_recording_version }}{% raw %}",
    "vcrpy{% endraw %}{{ vcrpy_version }}{% raw %}",{% endraw %}{% endif %}{% raw %}{% endraw %}{% if deploy_as_executable %}{% raw %}
    "pyinstaller{% endraw %}{{ pyinstaller_version }}{% raw %}",{% endraw %}{% endif %}{% raw %}{% endraw %}{% if is_circuit_python_driver %}{% raw %}
    "pytest-reserial{% endraw %}{{ pytest_reserial_version }}{% raw %}",
    "circup>=3.0.1",
    "adafruit-circuitpython-busdevice==5.2.17", # no specific reason for this version, just pinning to ensure no unintended drift during firmware builds
    "adafruit-circuitpython-register==1.11.3", # no specific reason for this version, just pinning to ensure no unintended drift during firmware builds{% endraw %}{% endif %}{% raw %}
]{% endraw %}{% if backend_uses_graphql %}{% raw %}

[tool.ariadne-codegen]
schema_path = "src/backend_api/schema.graphql"
include_comments = "none"
queries_path = "tests/e2e/queries/"
async_client = false
target_package_name = "backend"
target_package_path = "tests/e2e/generated/graphql"
enable_custom_operations = true{% endraw %}{% endif %}{% raw %}

[tool.uv]
package = true{% endraw %}{% if is_circuit_python_driver %}{% raw %}

[tool.circup.bundle-versions]
# WORKAROUND for https://github.com/adafruit/circup/issues/258 — circup currently strips `==X`
# specifiers when reading requirements.txt (circup/command_utils.py: libraries_from_requirements),
# so `circup install -r` installs whichever library version the active bundle release happens to
# contain, regardless of the pins we write into requirements.txt. Pinning the bundle release tag
# here makes that install deterministic: the bundle has exactly one version of each library, so
# whatever requirements.txt asks for, circup ends up installing the same versions every run, which
# is what the freeze-vs-requirements check in scripts/install_firmware_dependencies.py relies on.
# Remove this section once circup honors per-library pins in requirements.txt directly; the library
# version pins above stay either way. Bump both the dates here and the library pins together when
# intentionally moving to a newer bundle.
"adafruit/Adafruit_CircuitPython_Bundle" = "20260508" # no specific reason for this bundle version, just pinning to ensure no unintended drift during firmware builds (it contains the library versions currently pinned in pyproject.toml)
"adafruit/CircuitPython_Community_Bundle" = "20260414" # no specific reason for this bundle version, just pinning to ensure no unintended drift during firmware builds (it contains the library versions currently pinned in pyproject.toml){% endraw %}{% endif %}{% raw %}{% endraw %}
