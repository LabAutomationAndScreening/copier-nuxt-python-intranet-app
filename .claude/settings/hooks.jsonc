{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          // `git rev-parse --show-toplevel` is used for these to find the project root, since these commands are always guaranteed to be running within the repo's working tree
          {
            "type": "command",
            "command": "sh -c 'SESSION=$(jq -r \".session_id // \\\"default\\\"\" 2>/dev/null); printf \"%s\" \"$(git rev-parse --show-toplevel)\" > \"/tmp/.claude_project_root_${SESSION}\"'",
            "timeout": 5,
            "statusMessage": "Caching project root...",
          },
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.claude/hooks/caveman-activate.js\"",
            "timeout": 5,
            "statusMessage": "Loading caveman mode...",
          },
        ],
      },
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'INPUT=$(cat); SESSION=$(printf \"%s\" \"$INPUT\" | jq -r \".session_id // \\\"default\\\"\" 2>/dev/null); ROOT=$(cat \"${TMPDIR:-/tmp}/.claude_project_root_${SESSION:-default}\"); printf \"%s\" \"$INPUT\" | PROJECT_ROOT_DIR=\"$ROOT\" node \"$ROOT/.claude/hooks/caveman-mode-tracker.js\"'",
            "timeout": 5,
            "statusMessage": "Tracking caveman mode...",
          },
        ],
      },
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'INPUT=$(cat); SESSION=$(printf \"%s\" \"$INPUT\" | jq -r \".session_id // \\\"default\\\"\" 2>/dev/null); ROOT=$(cat \"${TMPDIR:-/tmp}/.claude_project_root_${SESSION:-default}\"); printf \"%s\" \"$INPUT\" | node \"$ROOT/.claude/hooks/bash-chain-guard.js\"'",
            "timeout": 5,
            "statusMessage": "Checking for command chaining...",
          },
        ],
      },
    ],
  },
}
